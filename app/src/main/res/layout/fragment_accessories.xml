<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFF9E7">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:gravity="center_vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_back"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="アクセサリー"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:gravity="center" />

        <View
            android:layout_width="80dp"
            android:layout_height="1dp" />

    </LinearLayout>

    <FrameLayout
        android:id="@+id/mendako_container"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp">

        <ImageView
            android:id="@+id/iv_mendako_body"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/mendako_body"
            android:contentDescription="@null" />

        <ImageView
            android:id="@+id/iv_mendako_eyes"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/mendako_eyes_normal"
            android:contentDescription="@null" />

        <ImageView
            android:id="@+id/iv_mendako_mouth"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/mendako_mouth_normal"
            android:contentDescription="@null" />

        <!-- アクセサリーは MendakoRenderer.applyAccessories が装備状態に応じて動的生成する。 -->

    </FrameLayout>

    <TextView
        android:id="@+id/tv_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="@string/msg_no_items"
        android:textSize="18sp"
        android:textColor="#999999"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_accessories"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false" />

</LinearLayout>
