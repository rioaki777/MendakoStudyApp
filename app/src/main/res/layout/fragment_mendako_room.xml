<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E8F4E8"
    android:padding="16dp">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_back"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/btn_back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/menu_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false"
        app:layout_constraintTop_toBottomOf="@id/btn_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="4dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_accessories"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="@string/btn_accessories"
            android:textSize="12sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            app:cornerRadius="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_food"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="@string/btn_food"
            android:textSize="12sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            app:cornerRadius="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_furniture"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="@string/btn_furniture"
            android:textSize="12sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            app:cornerRadius="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_select_mendako"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="@string/btn_select_mendako"
            android:textSize="12sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            app:cornerRadius="10dp" />

    </LinearLayout>

    <!-- 家具表示エリア。選択中メンダコの部屋の家具を描画する（メンダコ本体の背面）。
         アクセサリー/家具は比率座標で配置するため、編集画面と同じ正方形の縦横比に揃える。 -->
    <FrameLayout
        android:id="@+id/fl_room"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintTop_toBottomOf="@id/menu_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginTop="16dp" />

    <FrameLayout
        android:id="@+id/mendako_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleX="0.7"
        android:scaleY="0.7"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintTop_toBottomOf="@id/menu_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginTop="16dp">

        <ImageView
            android:id="@+id/iv_mendako_body"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/mendako_body"
            android:contentDescription="@null" />

        <ImageView
            android:id="@+id/iv_mendako_eyes"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/mendako_eyes_normal"
            android:contentDescription="@null" />

        <ImageView
            android:id="@+id/iv_mendako_mouth"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/mendako_mouth_normal"
            android:contentDescription="@null" />

        <ImageView
            android:id="@+id/iv_accessory_hat"
            android:layout_width="160dp"
            android:layout_height="96dp"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="4dp"
            android:src="@drawable/item_hat"
            android:contentDescription="@null"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/iv_accessory_scarf"
            android:layout_width="240dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:src="@drawable/item_scarf"
            android:contentDescription="@null"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/iv_accessory_ribbon"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/item_ribbon"
            android:contentDescription="@null"
            android:visibility="gone" />

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
