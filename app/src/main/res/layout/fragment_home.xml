<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_sea"
    android:padding="16dp">

    <!-- 泡（awa.png）が下から上へ立ち上るレイヤー。メンダコ等の背面に置く。
         クリックを奪わないよう非クリックにし、はみ出して描画できるよう clip を無効化。 -->
    <FrameLayout
        android:id="@+id/bubble_layer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clickable="false"
        android:focusable="false"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_points"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⭐ 0pt"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#333333"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/menu_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false"
        app:layout_constraintTop_toBottomOf="@id/tv_points"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_study"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="@string/btn_study"
            android:textSize="12sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            app:cornerRadius="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_shop"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="@string/btn_shop"
            android:textSize="12sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            app:cornerRadius="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_room"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="@string/btn_room"
            android:textSize="12sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            app:cornerRadius="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_friends"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="@string/btn_friends"
            android:textSize="12sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            app:cornerRadius="10dp" />

    </LinearLayout>

    <!-- 家具表示エリア。選択中メンダコの部屋の家具を描画する（メンダコ本体の背面）。
         アクセサリー/家具は比率座標で配置するため、編集画面と同じ正方形の縦横比に揃える。 -->
    <FrameLayout
        android:id="@+id/fl_room"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintTop_toBottomOf="@id/menu_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginTop="16dp" />

    <FrameLayout
        android:id="@+id/mendako_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleX="0.62"
        android:scaleY="0.62"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintTop_toBottomOf="@id/menu_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.85"
        android:layout_marginTop="16dp">

        <ImageView
            android:id="@+id/iv_mendako_body"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/mendako_body"
            android:contentDescription="@null" />

        <ImageView
            android:id="@+id/iv_mendako_eyes"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/mendako_eyes_normal"
            android:contentDescription="@null" />

        <ImageView
            android:id="@+id/iv_mendako_mouth"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/mendako_mouth_normal"
            android:contentDescription="@null" />

        <!-- アクセサリーは MendakoRenderer.applyAccessories が装備状態に応じて動的生成する。 -->

    </FrameLayout>

    <TextView
        android:id="@+id/tvVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v1.0"
        android:textSize="10sp"
        android:textColor="#AAAAAA"
        android:padding="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
